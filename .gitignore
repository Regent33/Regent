/tts-asr-local-models/
**/tts-asr-local-models/

# ── Secrets & local data (never commit) ──────────────
.env
.env.*
!.env.example
*.db
*.db-wal
*.db-shm
*.pem
*.key

# ── OS / editor cruft ────────────────────────────────
.DS_Store
Thumbs.db
*.log

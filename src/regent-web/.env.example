# LiveKit — works with self-hosted LiveKit OSS or LiveKit Cloud.
# The token route (app/api/token/route.ts) signs JWTs server-side with these,
# so the secret never reaches the browser. Copy to .env.local and fill in.

# Self-host (Docker):  ws://localhost:7880   (LiveKit OSS default)
# LiveKit Cloud:        wss://<your-project>.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# API key/secret from `livekit-server` config or the Cloud dashboard.
# LiveKit OSS dev default key/secret is devkey / secret (DO NOT use in prod).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
